{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "dev": false,
      "feat/automation-webhooks": false,
      "feat/kai-agent-rag": false,
      "feature/setup-project": false,
      "feature/testing-mcp-assistant": false
    }
  },
  "github": {
    "silent": true,
    "autoJobCancelation": true
  },
  "crons": [
    {
      "path": "/api/cron/check-expired-guests",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/auto-confirm-bookings",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/confirm-past-bookings",
      "schedule": "0 1 * * *"
    }
  ]
}
